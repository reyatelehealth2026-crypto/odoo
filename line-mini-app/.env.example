# Copy to `.env.local` for local development. Set values per environment in Vercel/hosting dashboard.

# Public base URL of the PHP backend (no trailing slash). Used by:
# - `src/lib/php-bridge.ts` — browser → `api/member.php` (CORS; must be HTTPS in production)
# - `src/app/api/checkout/route.ts` — Next.js server proxy → `api/checkout.php`
# - `src/app/api/checkout-slip/route.ts` — slip upload proxy
# - `src/app/api/miniapp-home/route.ts` — home feed proxy (if present)
NEXT_PUBLIC_PHP_API_BASE_URL=https://cny.re-ya.com

# LINE LIFF ID for this mini app (LINE Developers → LIFF app). Must match the **Endpoint URL**
# you register for the LIFF app (e.g. Next deploy URL), not `liff/index.php`, unless that is your chosen entry.
NEXT_PUBLIC_LINE_LIFF_ID=

# LINE Login channel ID (optional; used if UI needs it)
NEXT_PUBLIC_LINE_CHANNEL_ID=

# `line_accounts.id` in MySQL — scopes shop/member APIs to the correct OA tenant
NEXT_PUBLIC_LINE_ACCOUNT_ID=1

# Display name in `<title>` / metadata
NEXT_PUBLIC_MINIAPP_NAME=Re-Ya LINE Mini App
