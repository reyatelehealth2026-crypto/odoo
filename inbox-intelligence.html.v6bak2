<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inbox Intelligence Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    * { font-family: 'Noto Sans Thai', sans-serif; }
    body { background: #0f1623; }

    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: #1a2236; }
    ::-webkit-scrollbar-thumb { background: #3d4a6b; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #4e5f88; }

    .card { background: #1a2236; border: 1px solid #253047; border-radius: 14px; transition: border-color 0.2s; }
    .card:hover { border-color: #354163; }
    .card-sm { background: #212d45; border: 1px solid #2d3d5a; border-radius: 10px; }

    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .spinning { animation: spin 0.8s linear infinite; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    .fade-in { animation: fadeIn 0.35s ease-out; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
    .pulsing { animation: pulse 1.4s ease-in-out infinite; }

    .badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 9999px; font-size: 11px; font-weight: 500; border: 1px solid; }
    .badge-green  { background: rgba(16,185,129,0.12); color: #10b981; border-color: rgba(16,185,129,0.25); }
    .badge-yellow { background: rgba(245,158,11,0.12); color: #f59e0b; border-color: rgba(245,158,11,0.25); }
    .badge-red    { background: rgba(239,68,68,0.12);  color: #ef4444; border-color: rgba(239,68,68,0.25); }
    .badge-blue   { background: rgba(59,130,246,0.12); color: #60a5fa; border-color: rgba(59,130,246,0.25); }

    .stat-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }

    .funnel-bar { height: 28px; border-radius: 6px; transition: width 0.8s cubic-bezier(0.34,1.56,0.64,1); }

    table.data-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    table.data-table thead th { color: #6b7280; font-weight: 500; padding: 0 4px 10px; border-bottom: 1px solid #253047; white-space: nowrap; }
    table.data-table tbody td { padding: 8px 4px; border-bottom: 1px solid #1a2236; color: #d1d5db; vertical-align: middle; }
    table.data-table tbody tr:last-child td { border-bottom: none; }
    table.data-table tbody tr:hover td { background: rgba(255,255,255,0.02); }

    .gradient-green  { background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(16,185,129,0.04)); }
    .gradient-amber  { background: linear-gradient(135deg, rgba(245,158,11,0.15), rgba(245,158,11,0.04)); }
    .gradient-red    { background: linear-gradient(135deg, rgba(239,68,68,0.15), rgba(239,68,68,0.04)); }
    .gradient-blue   { background: linear-gradient(135deg, rgba(59,130,246,0.15), rgba(59,130,246,0.04)); }
    .gradient-purple { background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(139,92,246,0.04)); }

    input[type="number"] {
      background: #1a2236; border: 1px solid #253047; border-radius: 6px;
      color: #e5e7eb; padding: 3px 8px; font-size: 12px; outline: none; transition: border-color 0.2s;
    }
    input[type="number"]:focus { border-color: #10b981; }

    .section-title { font-size: 14px; font-weight: 600; color: #f1f5f9; display: flex; align-items: center; gap: 6px; }
    .section-sub { font-size: 11px; color: #4b5563; }
    .section-label {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 3px 10px; border-radius: 20px;
      font-size: 10px; font-weight: 600; letter-spacing: 0.05em;
      text-transform: uppercase; color: #4b5563;
      background: #1e2d45; border: 1px solid #253047;
      margin-bottom: 14px;
    }

    .header-bar { background: rgba(10,15,26,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid #1e2d45; }
    .refresh-btn {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 5px 12px; font-size: 12px;
      background: #1a2236; border: 1px solid #2d3d5a; border-radius: 8px;
      color: #9ca3af; cursor: pointer; transition: all 0.2s;
    }
    .refresh-btn:hover { border-color: #10b981; color: #10b981; }
    .refresh-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .empty-state    { text-align: center; padding: 32px 16px; color: #4b5563; font-size: 13px; }
    .empty-state-ok { text-align: center; padding: 24px 16px; color: #10b981; font-size: 13px; }

    .heatmap-cell { border-radius: 2px; transition: transform 0.15s; cursor: default; }
    .heatmap-cell:hover { transform: scale(1.4); z-index: 10; position: relative; }

    .cmp-card { background: #212d45; border: 1px solid #2d3d5a; border-radius: 10px; padding: 12px 14px; }

    /* section dividers */
    .section-divider {
      display: flex; align-items: center; gap: 12px;
      color: #374151; font-size: 11px; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 4px;
    }
    .section-divider::before, .section-divider::after {
      content: ''; flex: 1; height: 1px; background: #1e2d45;
    }
  </style>
</head>
<body class="min-h-screen text-gray-100">

  <!-- HEADER -->
  <header class="header-bar sticky top-0 z-50 px-4 py-3">
    <div class="max-w-screen-xl mx-auto flex items-center justify-between gap-3">
      <div class="flex items-center gap-3 min-w-0">
        <div class="stat-icon gradient-green shrink-0">
          <svg width="20" height="20" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <div class="min-w-0">
          <h1 class="text-base font-semibold text-white leading-tight">Inbox Intelligence</h1>
          <p class="text-xs text-gray-500 truncate" id="last-updated">กำลังโหลดข้อมูล…</p>
        </div>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <span class="text-xs text-gray-600 hidden sm:block">รีเฟรชอัตโนมัติทุก 5 นาที</span>
        <button class="refresh-btn" id="refresh-btn" onclick="refreshAll()">
          <svg id="refresh-icon" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
          </svg>
          รีเฟรช
        </button>
      </div>
    </div>
  </header>

  <main class="max-w-screen-xl mx-auto px-4 py-5 space-y-5">

    <!-- ════════════════════════════════════
         SECTION 1: INBOX OVERVIEW
    ════════════════════════════════════ -->
    <div class="section-divider">Inbox Overview</div>

    <!-- Summary Cards -->
    <div id="summary-cards" class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="card p-4 pulsing h-24"></div>
      <div class="card p-4 pulsing h-24"></div>
      <div class="card p-4 pulsing h-24"></div>
      <div class="card p-4 pulsing h-24"></div>
    </div>

    <!-- Traffic Comparison: Today vs Yesterday -->
    <div class="card p-5">
      <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
        <div class="section-title">
          <svg width="16" height="16" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          วันนี้ vs เมื่อวาน
        </div>
        <span class="section-sub">เปรียบเทียบ traffic รายวัน</span>
      </div>
      <div id="traffic-comparison-content">
        <div class="pulsing h-28 rounded-lg bg-white/5"></div>
      </div>
    </div>

    <!-- Response Time + Admin Performance -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            เวลาตอบสนองรายวัน
          </div>
          <span class="section-sub">7 วันล่าสุด</span>
        </div>
        <div id="response-time-chart-area" style="position:relative;height:200px;">
          <canvas id="responseTimeChart"></canvas>
        </div>
        <div id="response-time-table" class="mt-4 overflow-x-auto"></div>
      </div>

      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            ประสิทธิภาพแอดมิน
          </div>
          <span class="section-sub">7 วันล่าสุด</span>
        </div>
        <div id="admin-performance-table" class="overflow-x-auto">
          <div class="pulsing h-48 rounded-lg bg-white/5"></div>
        </div>
      </div>
    </div>

    <!-- SLA + Sentiment -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="card p-5">
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            SLA Monitor
          </div>
          <div class="flex items-center gap-1.5">
            <label class="text-xs text-gray-500">Threshold:</label>
            <input type="number" id="sla-threshold" value="30" min="1" max="999" style="width:56px;">
            <span class="text-xs text-gray-500">นาที</span>
            <button onclick="loadSLA()" class="text-xs px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/20 transition-colors">ค้นหา</button>
          </div>
        </div>
        <div id="sla-summary" class="grid grid-cols-2 gap-3 mb-4"></div>
        <div id="sla-table" class="overflow-x-auto max-h-56 overflow-y-auto pr-1"></div>
      </div>

      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Sentiment Tags
          </div>
          <span class="section-sub">7 วันล่าสุด</span>
        </div>
        <div id="sentiment-chart-area" style="position:relative;height:190px;">
          <canvas id="sentimentChart"></canvas>
        </div>
        <div id="sentiment-tags" class="mt-3 flex flex-wrap gap-1.5"></div>
      </div>
    </div>

    <!-- Peak Hours Heatmap -->
    <div class="card p-5">
      <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
        <div class="section-title">
          <svg width="16" height="16" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>
          Peak Hours Heatmap
        </div>
        <span class="section-sub">ข้อความ incoming 7 วันล่าสุด — ชั่วโมงไหนยุ่งสุด</span>
      </div>
      <div id="peak-hours-content">
        <div class="pulsing h-32 rounded-lg bg-white/5"></div>
      </div>
    </div>

    <!-- Message Type + Admin Workload -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#14b8a6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
            ประเภทข้อความ
          </div>
          <span class="section-sub">7 วันล่าสุด</span>
        </div>
        <div id="msg-type-chart-area" style="position:relative;height:200px;">
          <canvas id="msgTypeChart"></canvas>
        </div>
        <div id="msg-type-legend" class="mt-3 flex flex-wrap gap-2"></div>
      </div>

      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Workload แอดมิน
          </div>
          <span class="section-sub">ข้อความที่ส่งออก 7 วัน</span>
        </div>
        <div id="admin-workload-content">
          <div class="pulsing h-48 rounded-lg bg-white/5"></div>
        </div>
      </div>
    </div>

    <!-- Unread + Customer Journey -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            ข้อความที่ยังไม่อ่าน
          </div>
          <span id="unread-badge" class="badge badge-blue">—</span>
        </div>
        <div id="unread-table" class="overflow-x-auto max-h-64 overflow-y-auto pr-1">
          <div class="pulsing h-40 rounded-lg bg-white/5"></div>
        </div>
      </div>

      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            Customer Journey Funnel
          </div>
          <span class="section-sub">7 วันล่าสุด</span>
        </div>
        <div id="customer-journey-content">
          <div class="pulsing h-48 rounded-lg bg-white/5"></div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════
         SECTION 2: DAILY BUSINESS REPORT
    ════════════════════════════════════ -->
    <div class="section-divider">Daily Business Report</div>

    <!-- Daily KPI cards -->
    <div class="card p-5">
      <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
        <div class="section-title">
          <svg width="16" height="16" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          รายงานธุรกิจประจำวัน
        </div>
        <span id="daily-report-date" class="section-sub text-amber-400">—</span>
      </div>

      <!-- KPI Mini Cards -->
      <div id="daily-kpi-cards" class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-5">
        <div class="card-sm p-3 pulsing h-20"></div>
        <div class="card-sm p-3 pulsing h-20"></div>
        <div class="card-sm p-3 pulsing h-20"></div>
        <div class="card-sm p-3 pulsing h-20"></div>
        <div class="card-sm p-3 pulsing h-20"></div>
        <div class="card-sm p-3 pulsing h-20"></div>
      </div>

      <!-- Messages today inline badge row -->
      <div id="daily-msgs-today" class="flex flex-wrap items-center gap-2 mb-4 text-xs"></div>

      <!-- Trend + Hourly charts -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
        <div>
          <p class="text-xs text-gray-500 mb-2">📈 Trend ออเดอร์ 7 วัน</p>
          <div id="daily-trend-area" style="position:relative;height:180px;">
            <div class="pulsing h-full rounded-lg bg-white/5"></div>
          </div>
        </div>
        <div>
          <p class="text-xs text-gray-500 mb-2">🕐 Hourly Traffic วันนี้</p>
          <div id="hourly-traffic-area" style="position:relative;height:180px;">
            <div class="pulsing h-full rounded-lg bg-white/5"></div>
          </div>
        </div>
      </div>

      <!-- Tables: Top Admins, Customers, Salespeople, Overdue -->
      <div id="daily-tables-row" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <div class="card-sm p-3 pulsing h-48"></div>
        <div class="card-sm p-3 pulsing h-48"></div>
        <div class="card-sm p-3 pulsing h-48"></div>
      </div>
    </div>

    <!-- ════════════════════════════════════
         SECTION 3: PRODUCT INTELLIGENCE
    ════════════════════════════════════ -->
    <div class="section-divider">Product Intelligence</div>

    <!-- Low Stock Alert Banner -->
    <div id="low-stock-banner">
      <div class="pulsing h-20 rounded-xl bg-white/5"></div>
    </div>

    <!-- Trending Products + Category Distribution -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

      <!-- Trending products table — takes 2/3 -->
      <div class="card p-5 lg:col-span-2">
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            Trending Products ที่ลูกค้าถาม
          </div>
          <span class="section-sub">7 วันล่าสุด · top 30</span>
        </div>
        <div id="trending-products-content">
          <div class="pulsing h-64 rounded-lg bg-white/5"></div>
        </div>
      </div>

      <!-- Category Distribution — takes 1/3 -->
      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="section-title">
            <svg width="16" height="16" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 10 10"/><line x1="12" y1="12" x2="12" y2="2"/></svg>
            Category Distribution
          </div>
        </div>
        <div id="product-categories-area">
          <div class="pulsing h-48 rounded-lg bg-white/5"></div>
        </div>
      </div>

    </div>

  </main>

  <footer class="text-center py-4 text-xs text-gray-700 mt-2">
    Inbox Intelligence Dashboard v2 · Auto-refresh ทุก 5 นาที
  </footer>

  <script src="/inbox-intelligence-v6.js"></script>
</body>
</html>
