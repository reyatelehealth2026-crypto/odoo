# LINE CRM - Apache Configuration for re-ya.com
# Clean URLs without .php extension

# Enable RewriteEngine
RewriteEngine On

# Base path - root domain (re-ya.com)
RewriteBase /

# =====================================================
# SEO Files - Dynamic sitemap.xml and robots.txt
# Requirements: 9.1, 9.2, 9.3, 9.4, 9.5
# =====================================================
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^robots\.txt$ robots.php [L]

# =====================================================
# Redirect Old LIFF Files to LIFF SPA (/liff/index.php)
# =====================================================
# All old liff-*.php files redirect to liff/index.php with page parameter
RewriteRule ^liff-app\.php$ /liff/index.php?page=app [R=301,L,QSA]
RewriteRule ^liff-appointment\.php$ /liff/index.php?page=appointment [R=301,L,QSA]
RewriteRule ^liff-checkout\.php$ /liff/index.php?page=checkout [R=301,L,QSA]
RewriteRule ^liff-consent\.php$ /liff/index.php?page=consent [R=301,L,QSA]
RewriteRule ^liff-main\.php$ /liff/index.php?page=main [R=301,L,QSA]
RewriteRule ^liff-member-card\.php$ /liff/index.php?page=member [R=301,L,QSA]
RewriteRule ^liff-my-appointments\.php$ /liff/index.php?page=appointments [R=301,L,QSA]
RewriteRule ^liff-my-orders\.php$ /liff/index.php?page=orders [R=301,L,QSA]
RewriteRule ^liff-order-detail\.php$ /liff/index.php?page=order-detail [R=301,L,QSA]
RewriteRule ^liff-pharmacy-consult\.php$ /liff/index.php?page=consult [R=301,L,QSA]
RewriteRule ^liff-points-history\.php$ /liff/index.php?page=points [R=301,L,QSA]
RewriteRule ^liff-points-rules\.php$ /liff/index.php?page=points-rules [R=301,L,QSA]
RewriteRule ^liff-product-detail\.php$ /liff/index.php?page=product [R=301,L,QSA]
RewriteRule ^liff-promotions\.php$ /liff/index.php?page=promotions [R=301,L,QSA]
RewriteRule ^liff-redeem-points\.php$ /liff/index.php?page=redeem [R=301,L,QSA]
RewriteRule ^liff-register\.php$ /liff/index.php?page=register [R=301,L,QSA]
RewriteRule ^liff-settings\.php$ /liff/index.php?page=settings [R=301,L,QSA]
RewriteRule ^liff-share\.php$ /liff/index.php?page=share [R=301,L,QSA]
RewriteRule ^liff-shop\.php$ /liff/index.php?page=shop [R=301,L,QSA]
RewriteRule ^liff-shop-v3\.php$ /liff/index.php?page=shop [R=301,L,QSA]
RewriteRule ^liff-symptom-assessment\.php$ /liff/index.php?page=symptom [R=301,L,QSA]
RewriteRule ^liff-video-call\.php$ /liff/index.php?page=video-call [R=301,L,QSA]
RewriteRule ^liff-video-call-pro\.php$ /liff/index.php?page=video-call [R=301,L,QSA]
RewriteRule ^liff-wishlist\.php$ /liff/index.php?page=wishlist [R=301,L,QSA]

# =====================================================
# Clean URLs - ไม่ต้องพิมพ์ .php
# เช่น /broadcast แทน /broadcast.php
# =====================================================

# ถ้าไม่ใช่ไฟล์หรือโฟลเดอร์จริง ให้ลองหา .php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# รองรับ subdirectory เช่น /shop/products, /api/checkout
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/([^/]+)/?$ $1/$2.php [L]

# รองรับ 3 levels เช่น /api/shop/products
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/([^/]+)/([^/]+)/?$ $1/$2/$3.php [L]

# =====================================================

# Set default charset
AddDefaultCharset UTF-8

# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect config files
<FilesMatch "config\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect lock file
<FilesMatch "installed\.lock$">
    Order allow,deny
    Deny from all
</FilesMatch>

# =====================================================
# Security Headers (expanded 2026-05-05)
# =====================================================
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# Stable ETag (avoid INode component on shared/clustered LiteSpeed)
FileETag MTime Size

# =====================================================
# PHP Settings (for mod_php)
# =====================================================
<IfModule mod_php.c>
    php_flag display_errors off
    php_flag log_errors on
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_execution_time 300
    php_value memory_limit 256M
    php_value date.timezone "Asia/Bangkok"
    php_value default_charset "UTF-8"
    php_value mbstring.internal_encoding "UTF-8"
</IfModule>

# PHP Settings (for PHP-FPM / FastCGI)
<IfModule mod_fcgid.c>
    FcgidInitialEnv PHP_FCGI_CHILDREN 0
</IfModule>

# =====================================================
# Compression — gzip / brotli (Apache mod_deflate + LiteSpeed)
# =====================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
    <IfModule mod_headers.c>
        Header append Vary Accept-Encoding
    </IfModule>
</IfModule>
<IfModule LiteSpeed>
    CacheCompressMaxFileSize 5000000
</IfModule>

# =====================================================
# Browser Caching — Expires + Cache-Control
# =====================================================
<IfModule mod_expires.c>
    ExpiresActive On
    # HTML/PHP — never long-cache (dynamic content)
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/xhtml+xml "access plus 0 seconds"
    # CSS / JS — 1 month (use ?v=filemtime in templates for cache busting)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    # Images — 1 year (immutable assets)
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
    # Fonts — 1 year
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    # JSON / XML data — no cache
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
    ExpiresDefault "access plus 1 week"
</IfModule>

# Cache-Control headers (modern browsers + CDNs prefer this over Expires)
<IfModule mod_headers.c>
    <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    <FilesMatch "\.(php|html)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>
