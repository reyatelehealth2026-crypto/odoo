{
  "name": "telepharmacy-websocket-server",
  "version": "1.0.0",
  "description": "WebSocket server for LINE Telepharmacy Platform Inbox v2 real-time updates",
  "main": "websocket-server.js",
  "scripts": {
    "start": "node websocket-server.js",
    "dev": "nodemon websocket-server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:js": "terser odoo-dashboard.js -o odoo-dashboard.min.js --compress passes=2,dead_code,drop_console --mangle --source-map \"filename='odoo-dashboard.min.js.map',url='odoo-dashboard.min.js.map'\"",
    "build:css": "node scripts/extract-css.js 2>/dev/null || echo 'CSS build script not found, skipping'",
    "build": "npm run build:js",
    "pm2:start": "pm2 start websocket-server.js --name telepharmacy-ws",
    "pm2:stop": "pm2 stop telepharmacy-ws",
    "pm2:restart": "pm2 restart telepharmacy-ws",
    "pm2:logs": "pm2 logs telepharmacy-ws",
    "pm2:monit": "pm2 monit"
  },
  "keywords": [
    "websocket",
    "socket.io",
    "real-time",
    "telepharmacy",
    "inbox",
    "chat"
  ],
  "author": "LINE Telepharmacy Platform",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "redis": "^3.1.2",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "mysql2": "^3.20.0",
    "nodemon": "^3.0.2",
    "terser": "^5.31.0"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
