.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Cache
.cache/
.npm/
.yarn/

# Test files
coverage/
.nyc_output/
test-results/

# TypeScript
*.tsbuildinfo

# Prisma
prisma/migrations/
!prisma/schema.prisma
!prisma/seed.ts

# Temporary files
*.tmp
*.temp

# Documentation
*.md
!README.md