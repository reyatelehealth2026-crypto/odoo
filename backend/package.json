{
  "name": "odoo-dashboard-backend",
  "version": "1.0.0",
  "description": "Modern Node.js backend API for Odoo Dashboard modernization",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:system": "tsx src/test/system/run-comprehensive-tests.ts",
    "test:properties": "vitest --run src/test/system/comprehensive-system-test.ts src/test/system/comprehensive-system-test-part2.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx src/prisma/seed.ts",
    "prisma:validate": "tsx src/scripts/validate-migration.ts",
    "db:reset": "prisma migrate reset --force && npm run prisma:seed"
  },
  "keywords": ["fastify", "typescript", "prisma", "odoo", "dashboard"],
  "author": "LINE Telepharmacy Platform",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.4.2",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/redis": "^6.1.1",
    "@fastify/swagger": "^8.12.0",
    "@fastify/swagger-ui": "^2.1.0",
    "@prisma/client": "^5.8.1",
    "fastify": "^4.25.2",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.4",
    "dotenv": "^16.3.1",
    "sharp": "^0.33.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/sharp": "^0.32.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prisma": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.3",
    "@vitest/coverage-v8": "^1.1.3",
    "fast-check": "^3.15.1",
    "@types/supertest": "^6.0.2",
    "supertest": "^6.3.4",
    "testcontainers": "^10.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}