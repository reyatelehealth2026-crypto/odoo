# Test Environment Configuration
DATABASE_URL="mysql://root:password@localhost:3306/telepharmacy_test"

# JWT Configuration
JWT_SECRET="test-jwt-secret-key-for-testing-only"
JWT_REFRESH_SECRET="test-refresh-secret-key-for-testing-only"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# Server Configuration
PORT=3001
NODE_ENV="test"
API_PREFIX="/api/v1"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS Configuration
CORS_ORIGIN="http://localhost:3000"

# Logging
LOG_LEVEL="error"

# External Services
ODOO_API_URL="https://test-odoo.example.com"
ODOO_API_KEY="test-api-key"

# WebSocket Configuration
WEBSOCKET_PORT=3002