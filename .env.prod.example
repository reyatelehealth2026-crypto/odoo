# Production Environment Variables
# Copy this file to .env.prod and update with secure values

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=telepharmacy_prod
DB_USER=telepharmacy_prod
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DATABASE_URL=mysql://telepharmacy_prod:CHANGE_ME_SECURE_PASSWORD@mysql:3306/telepharmacy_prod

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# JWT Configuration
JWT_SECRET=CHANGE_ME_SUPER_SECURE_JWT_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_REFRESH_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
PORT=4000
API_HOST=0.0.0.0
API_PREFIX=/api/v1
CORS_ORIGIN=https://your-domain.com

# WebSocket Configuration
WEBSOCKET_PORT=3001
WEBSOCKET_HOST=0.0.0.0
ALLOWED_ORIGINS=https://your-domain.com

# Frontend Configuration
NEXT_PUBLIC_API_URL=/api/v1
INTERNAL_API_ORIGIN=http://backend:4000
NEXT_PUBLIC_WS_URL=wss://your-domain.com
NEXT_TELEMETRY_DISABLED=1

# Production URLs
DOMAIN_NAME=your-domain.com
FRONTEND_URL=https://your-domain.com
API_URL=/api/v1
WS_URL=wss://your-domain.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_SWAGGER=false
ENABLE_DEBUG=false
ENABLE_HOT_RELOAD=false
ENABLE_DEMO_DASHBOARD=false

# Performance
CACHE_TTL=3600
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=50

# Security
HELMET_ENABLED=true
RATE_LIMITING_ENABLED=true

# Thai Timezone
TZ=Asia/Bangkok

# SSL Configuration (if using custom certificates)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Monitoring
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30