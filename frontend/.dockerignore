# Frontend Docker ignore file
# Optimizes Next.js build context

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
.next/
out/
dist/
build/

# Environment files
.env*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Cache
.cache/
.npm/
.yarn/

# Test files
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# Temporary files
*.tmp
*.temp

# Documentation
*.md
!README.md